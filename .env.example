# ── COPY THIS TO .env AND FILL IN YOUR VALUES ──────────────────────────────
# Never commit .env to git — it is in .gitignore

# ── GitHub OAuth ────────────────────────────────────────────────────────────
# Required for dashboard authentication.
# Create a GitHub App at https://github.com/settings/apps
#   - Set callback URL to: https://scalper.yourdomain.com/auth/callback
#   - Permissions: Account > Email addresses (read-only)
GITHUB_CLIENT_ID=your_github_app_client_id
GITHUB_CLIENT_SECRET=your_github_app_client_secret

# Comma-separated GitHub usernames allowed to access the dashboard
AUTHORIZED_USERS=yourgithubusername

# Random secret for signing session cookies — generate once and keep secret:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=generate_a_random_string_here

# Public URL of your dashboard (no trailing slash)
APP_URL=https://scalper.yourdomain.com


# Set to "false" to switch to live trading (defaults to "true" = testnet)
TESTNET=true

# Testnet credentials (https://testnet.binance.vision)
BINANCE_API_KEY_TEST=your_testnet_api_key_here
BINANCE_API_SECRET_TEST=your_testnet_api_secret_here

# Live credentials (Binance → Profile → API Management)
# Permissions needed: Spot & Margin trading. Disable: Withdrawals.
# Whitelist your VPS IP address before enabling live trading.
BINANCE_API_KEY_LIVE=your_live_api_key_here
BINANCE_API_SECRET_LIVE=your_live_api_secret_here

# ── Trading hours (UTC) ─────────────────────────────────────────────────────
# Restrict new entries to specific hours. Leave empty for unrestricted trading.
# Open positions continue to be managed outside trading hours.
# Supports overnight windows e.g. 22:00 to 06:00
# TRADING_HOURS_START=08:00
# TRADING_HOURS_END=20:00

# ── Proxy / VPN ────────────────────────────────────────────────────────────
# Route ccxt traffic through a SOCKS5 proxy to bypass geo-restrictions.
# Production: gluetun sidecar handles this automatically via docker-compose.
# Local testing: ssh -D 1080 -N user@your-vps → set SOCKS_PROXY=socks5h://localhost:1080
# Leave empty for direct connection (testnet, unrestricted regions).
SOCKS_PROXY=socks5h://gluetun:1080

# ProtonVPN WireGuard credentials for gluetun
# Get from: https://account.proton.me/vpn/wireguard
# Create a WireGuard certificate and copy the PrivateKey value
WIREGUARD_PRIVATE_KEY=your_wireguard_private_key_here
SERVER_COUNTRIES=Switzerland

# ── Cooldown ───────────────────────────────────────────────────────────────
# Candles to wait before re-entering a symbol you manually closed.
# Default 3 candles = 15min on 5m. Prevents immediate re-entry after manual close.
MANUAL_CLOSE_COOLDOWN_CANDLES=3

# ── Logging ────────────────────────────────────────────────────────────────
# INFO (default): trades, cycle summaries, errors
# DEBUG: shows why each candidate was rejected (entry filter detail, qty skips, OCO checks)
LOG_LEVEL=INFO

# ── Strategy parameters (all optional — defaults shown) ────────────────────
TIMEFRAME=5m
MAX_SYMBOLS=20
MIN_VOLUME_USDT=5000000
MAX_SPREAD_PCT=0.08

# Entry filters
ADX_MIN=25
RSI_MIN=50
RSI_MAX=65

# Risk & exits
TRAILING_STOP_PCT=0.8
# Seed value for the trailing-stop activation threshold (UI-toggled, in-memory).
# This sets the default percentage only — the feature is turned on/off from the
# dashboard Controls panel. When active, a new position's trailing stop stays
# dormant until price first reaches entry*(1+this%); until then the server-side
# stop-market is the sole protection. Helps avoid whipsaw exits right after entry.
TRAILING_ACTIVATION_PCT=1.0

# ── BTC market-regime filter (UI-toggled, in-memory) ────────────────────────
# These set default VALUES only — the filter is enabled/disabled from the
# dashboard Controls panel. When active, new entries are paused if BTC's price
# has fallen more than BTC_TREND_THRESHOLD_PCT over the last BTC_TREND_LOOKBACK
# candles. Open positions are never affected. The BTC regime is logged on every
# trade regardless of whether the filter is enforced, so you can correlate
# win-rate against BTC trend before turning it on.
BTC_TREND_LOOKBACK=3
BTC_TREND_THRESHOLD_PCT=0.15
# Set to false to disable take profit and let the trailing stop be the sole exit.
# Allows winners to run indefinitely — trailing stop locks in gains as price rises.
TAKE_PROFIT_ENABLED=true
TAKE_PROFIT_PCT=1.5
MAX_OPEN_POSITIONS=3
MAX_HOLD_CANDLES=12
RISK_PER_TRADE_PCT=1.0
MAX_PORTFOLIO_PCT=30.0
MIN_TRADE_USDT=11.0

# Loop interval in seconds (≥ candle close time to avoid re-entering)
POLL_INTERVAL=60

# Comma-separated symbols to never trade
# Exclude: failed coins, stablecoins, and any coin whose price causes qty to round to 0
BLACKLIST=LUNA/USDT,UST/USDT,FDUSD/USDT,USDC/USDT,EUR/USDT,USD1/USDT,RLUSD/USDT,GENIUS/USDT


# ── Strategy profiles ───────────────────────────────────────────────────────
# Uncomment one profile block at a time. Profile A is the default.

# Profile A — Conservative (default)
# High-liquidity coins only (BTC, ETH, SOL, BNB, XRP etc).
# Stricter trend confirmation means fewer but higher-quality entries.
# Best for: preserving capital while generating steady small gains.
TIMEFRAME=5m
MAX_SYMBOLS=20
MIN_VOLUME_USDT=5000000
MAX_SPREAD_PCT=0.08
ADX_MIN=28
RSI_MIN=52
RSI_MAX=62
TRAILING_STOP_PCT=0.8
# Seed value for the trailing-stop activation threshold (UI-toggled, in-memory).
# This sets the default percentage only — the feature is turned on/off from the
# dashboard Controls panel. When active, a new position's trailing stop stays
# dormant until price first reaches entry*(1+this%); until then the server-side
# stop-market is the sole protection. Helps avoid whipsaw exits right after entry.
TRAILING_ACTIVATION_PCT=1.0

# ── BTC market-regime filter (UI-toggled, in-memory) ────────────────────────
# These set default VALUES only — the filter is enabled/disabled from the
# dashboard Controls panel. When active, new entries are paused if BTC's price
# has fallen more than BTC_TREND_THRESHOLD_PCT over the last BTC_TREND_LOOKBACK
# candles. Open positions are never affected. The BTC regime is logged on every
# trade regardless of whether the filter is enforced, so you can correlate
# win-rate against BTC trend before turning it on.
BTC_TREND_LOOKBACK=3
BTC_TREND_THRESHOLD_PCT=0.15
# Set to false to disable take profit and let the trailing stop be the sole exit.
# Allows winners to run indefinitely — trailing stop locks in gains as price rises.
TAKE_PROFIT_ENABLED=true
TAKE_PROFIT_PCT=1.2
MAX_OPEN_POSITIONS=3
MAX_HOLD_CANDLES=12
RISK_PER_TRADE_PCT=1.0
MAX_PORTFOLIO_PCT=25.0
MIN_TRADE_USDT=11.0

# Profile B — Mid-cap momentum
# Opens the universe to mid-caps (XLM, INJ, STG etc).
# Compensates for lower liquidity with stricter trend filters and wider stops.
# Best for: larger gains per trade at the cost of higher individual coin risk.
# Note: coins showing >15% 24h gain are still filtered by RSI (they'll be overbought).
#TIMEFRAME=5m
#MAX_SYMBOLS=30
#MIN_VOLUME_USDT=1000000
#MAX_SPREAD_PCT=0.15
#ADX_MIN=30
#RSI_MIN=52
#RSI_MAX=62
#TRAILING_STOP_PCT=1.2
#TAKE_PROFIT_PCT=2.0
#MAX_OPEN_POSITIONS=3
#MAX_HOLD_CANDLES=16
#RISK_PER_TRADE_PCT=0.8
#MAX_PORTFOLIO_PCT=20.0
#MIN_TRADE_USDT=11.0

# ── Server-side backstops ────────────────────────────────────────────────────
# OCO (One-Cancels-Other): preferred, fires take-profit + stop-loss server-side
OCO_ENABLED=true
OCO_STOP_PCT=2.0

# Stop-limit fallback for pairs that don't support OCO (e.g. NEAR, FET, ALLO)
# Trigger = entry * (1 - (TRAILING_STOP_PCT + STOP_LIMIT_OFFSET_PCT))
# Fires just below the trailing stop — only triggers if the bot dies mid-trade
# Default offset of 0.05% means trailing=1.2% → stop-limit triggers at 1.25%
STOP_LIMIT_OFFSET_PCT=0.05
# Limit price buffer below stop trigger — ensures fill during fast drops
STOP_LIMIT_FILL_BUFFER_PCT=0.1
